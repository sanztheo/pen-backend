generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  email                    String               @unique @db.VarChar(255)
  avatarUrl                String?              @map("avatar_url")
  createdAt                DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  firstName                String               @map("first_name") @db.VarChar(100)
  isActive                 Boolean              @default(true) @map("is_active")
  lastLoginAt              DateTime?            @map("last_login_at") @db.Timestamptz(6)
  lastName                 String               @map("last_name") @db.VarChar(100)
  updatedAt                DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  id                       String               @id @db.VarChar(255)
  isAdmin                  Boolean              @default(false) @map("is_admin")
  autocompletionEnabled    Boolean              @default(true) @map("autocompletion_enabled")
  onboardingCompleted      Boolean              @default(false) @map("onboarding_completed")
  settings                 Json?                @default("{}")
  // 🎯 Beta Management
  betaStatus               BetaStatus           @default(active) @map("beta_status")
  betaJoinedAt             DateTime?            @map("beta_joined_at") @db.Timestamptz(6)
  betaDeactivatedAt        DateTime?            @map("beta_deactivated_at") @db.Timestamptz(6)
  betaReactivationDeadline DateTime?            @map("beta_reactivation_deadline") @db.Timestamptz(6)
  // 📊 Activity Tracking (silent)
  totalActiveTimeSeconds   Int                  @default(0) @map("total_active_time_seconds")
  weeklyActiveTimeSeconds  Int                  @default(0) @map("weekly_active_time_seconds")
  weeklySessionCount       Int                  @default(0) @map("weekly_session_count")
  lastHeartbeatAt          DateTime?            @map("last_heartbeat_at") @db.Timestamptz(6)
  lastActiveAt             DateTime?            @map("last_active_at") @db.Timestamptz(6)
  activityLogs             ActivityLog[]
  pages                    Page[]               @relation("PageAuthor")
  projects                 Project[]            @relation("ProjectOwner")
  quizSequences            QuizSequence[]
  quizTemplates            QuizTemplate[]
  quizzes                  Quiz[]
  usageRecords             UsageRecord[]
  userLimits               UserLimits?
  quizPreferences          UserQuizPreferences?
  subscription             UserSubscription?
  invitedMembers           WorkspaceMember[]    @relation("InvitedBy")
  workspaceMembers         WorkspaceMember[]
  ownedWorkspaces          Workspace[]          @relation("WorkspaceOwner")
  // 💬 AI Conversations
  aiConversations          AIConversation[]
  // 📊 Quiz Dashboard Layout
  dashboardLayout          UserDashboardLayout?
  // 🎯 Beta Waitlist
  betaWaitlistEntries      BetaWaitlist[]
  // 📝 Admin Notes
  adminNotesOnUser         AdminNote[]          @relation("AdminNotesOnUser")
  adminNotesByAdmin        AdminNote[]          @relation("AdminNotesByAdmin")

  @@index([betaStatus])
  @@index([lastLoginAt])
  @@index([totalActiveTimeSeconds])
  @@index([betaJoinedAt])
  @@map("users")
}

model BetaWaitlist {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email      String    @unique @db.VarChar(255)
  userId     String?   @map("user_id") @db.VarChar(255)
  name       String    @db.VarChar(200)
  joinedAt   DateTime  @default(now()) @map("joined_at") @db.Timestamptz(6)
  notifiedAt DateTime? @map("notified_at") @db.Timestamptz(6)
  metadata   Json?     @default("{}")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([joinedAt])
  @@index([userId])
  @@map("beta_waitlist")
}

model Workspace {
  name            String            @db.VarChar(255)
  description     String?
  color           String?           @default("#3B82F6") @db.VarChar(7)
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  isArchived      Boolean           @default(false) @map("is_archived")
  lastActivityAt  DateTime          @default(now()) @map("last_activity_at") @db.Timestamptz(6)
  ownerId         String            @map("owner_id") @db.VarChar(255)
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  activityLogs    ActivityLog[]
  pages           Page[]
  projects        Project[]
  members         WorkspaceMember[]
  owner           User              @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  // 💬 AI Conversations
  aiConversations AIConversation[]

  @@unique([ownerId, name])
  @@map("workspaces")
}

model WorkspaceMember {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  userId      String    @map("user_id") @db.VarChar(255)
  role        String    @default("member") @db.VarChar(20)
  permissions Json      @default("{}")
  invitedBy   String?   @map("invited_by") @db.VarChar(255)
  invitedAt   DateTime  @default(now()) @map("invited_at") @db.Timestamptz(6)
  joinedAt    DateTime? @map("joined_at") @db.Timestamptz(6)
  isActive    Boolean   @default(true) @map("is_active")
  inviter     User?     @relation("InvitedBy", fields: [invitedBy], references: [id])
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

model Project {
  name           String        @db.VarChar(255)
  description    String?
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy      String        @map("created_by") @db.VarChar(255)
  isArchived     Boolean       @default(false) @map("is_archived")
  lastActivityAt DateTime      @default(now()) @map("last_activity_at") @db.Timestamptz(6)
  settings       Json          @default("{}")
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  workspaceId    String        @map("workspace_id") @db.Uuid
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  position       Int           @default(0)
  isPinned       Boolean       @default(false) @map("is_pinned")
  parentId       String?       @map("parent_id") @db.Uuid // 🚀 Nouveau: support des projets imbriqués
  activityLogs   ActivityLog[]
  pages          Page[]
  owner          User          @relation("ProjectOwner", fields: [createdBy], references: [id])
  workspace      Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parent         Project?      @relation("ProjectHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children       Project[]     @relation("ProjectHierarchy")

  @@index([createdBy])
  @@map("projects")
}

model Page {
  title            String        @db.VarChar(255)
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  createdBy        String        @map("created_by") @db.VarChar(255)
  isArchived       Boolean       @default(false) @map("is_archived")
  parentId         String?       @map("parent_id") @db.Uuid
  position         Int           @default(0)
  projectId        String?       @map("project_id") @db.Uuid
  slug             String?       @db.VarChar(255)
  updatedAt        DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  blockNoteContent Json?         @map("block_note_content")
  workspaceId      String        @map("workspace_id") @db.Uuid
  isPinned         Boolean       @default(false) @map("is_pinned")
  icon             String?       @db.VarChar(50)
  iconColor        String?       @map("icon_color") @db.VarChar(7)
  activityLogs     ActivityLog[]
  aiMessages       AIMessage[] // Messages AI qui ont créé cette page
  author           User          @relation("PageAuthor", fields: [createdBy], references: [id])
  parent           Page?         @relation("PageHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children         Page[]        @relation("PageHierarchy")
  project          Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workspace        Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  yjsDocument      YjsDocument?
  // 🧠 Quiz Intelligence - Concepts pré-extraits pour génération optimisée
  concepts         PageConcepts?

  @@index([createdBy])
  @@map("pages")
}

// 🧠 Quiz Intelligence - Concepts pré-extraits des pages
// Permet le clustering thématique et la sélection intelligente pour les quiz
model PageConcepts {
  id     String @id @default(cuid())
  pageId String @unique @map("page_id") @db.Uuid

  // 📚 Contenu extrait
  keywords    String[] // Mots-clés principaux
  definitions Json? // {term: definition} pour les termes importants
  keyPoints   String[] @map("key_points") // Points clés du contenu
  formulas    String[] // Formules mathématiques/scientifiques
  summary     String?  @db.Text // Résumé court du contenu

  // 🎯 Métadonnées pour clustering
  embedding  Float[] // Vecteur d'embedding pour similarité
  topic      String? @db.VarChar(100) // Thème principal détecté
  difficulty String  @default("medium") @db.VarChar(20) // easy, medium, hard

  // 📊 Statistiques
  wordCount    Int @default(0) @map("word_count")
  conceptCount Int @default(0) @map("concept_count")

  // ⏰ Timestamps
  lastExtractedAt DateTime @default(now()) @map("last_extracted_at") @db.Timestamptz(6)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // 🔗 Relation
  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
  @@index([topic])
  @@map("page_concepts")
}

model ActivityLog {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String     @map("user_id") @db.VarChar(255)
  workspaceId String?    @map("workspace_id") @db.Uuid
  projectId   String?    @map("project_id") @db.Uuid
  pageId      String?    @map("page_id") @db.Uuid
  action      String     @db.VarChar(100)
  entityType  String     @map("entity_type") @db.VarChar(50)
  entityId    String     @map("entity_id") @db.VarChar(255)
  details     Json       @default("{}")
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  page        Page?      @relation(fields: [pageId], references: [id])
  project     Project?   @relation(fields: [projectId], references: [id])
  user        User       @relation(fields: [userId], references: [id])
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  @@index([userId])
  @@map("activity_logs")
}

model YjsDocument {
  id        String      @id @default(cuid())
  pageId    String      @unique @map("page_id") @db.Uuid
  data      Bytes
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  page      Page        @relation(fields: [pageId], references: [id], onDelete: Cascade)
  updates   YjsUpdate[]

  @@map("yjs_documents")
}

model YjsUpdate {
  id         String      @id @default(cuid())
  documentId String      @map("document_id")
  data       Bytes
  createdAt  DateTime    @default(now()) @map("created_at")
  document   YjsDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("yjs_updates")
}

model UserQuizPreferences {
  id                   String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId               String           @unique @map("user_id") @db.VarChar(255)
  schoolLevel          SchoolLevel      @map("school_level")
  lyceeSpecialties     LyceeSpecialty[] @map("lycee_specialties")
  higherEdField        String?          @map("higher_ed_field") @db.VarChar(255)
  preferredWorkspace   String?          @map("preferred_workspace") @db.Uuid
  targetGrade          Float?           @map("target_grade")
  questionTypes        QuestionType[]   @default([MULTIPLE_CHOICE, TRUE_FALSE]) @map("question_types")
  defaultQuestionCount Int              @default(20) @map("default_question_count")
  createdAt            DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  collegeGrade         CollegeGrade?    @map("college_grade")
  user                 User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_quiz_preferences")
}

model QuizTemplate {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String           @map("user_id") @db.VarChar(255)
  title            String           @db.VarChar(255)
  description      String?
  schoolLevel      SchoolLevel      @map("school_level")
  lyceeSpecialties LyceeSpecialty[] @map("lycee_specialties")
  higherEdField    String?          @map("higher_ed_field") @db.VarChar(255)
  workspaceIds     String[]         @map("workspace_ids") @db.Uuid
  questionTypes    QuestionType[]   @map("question_types")
  questionCount    Int              @default(20) @map("question_count")
  targetGrade      Float?           @map("target_grade")
  parameters       Json             @default("{}")
  isPublic         Boolean          @default(false) @map("is_public")
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  collegeGrade     CollegeGrade?    @map("college_grade")
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizzes          Quiz[]

  @@index([userId])
  @@map("quiz_templates")
}

model Quiz {
  id                  String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  templateId          String?          @map("template_id") @db.Uuid
  userId              String           @map("user_id") @db.VarChar(255)
  title               String           @db.VarChar(255)
  schoolLevel         SchoolLevel      @map("school_level")
  questions           Json
  userAnswers         Json?            @map("user_answers")
  isCompleted         Boolean          @default(false) @map("is_completed")
  timeSpent           Int?             @map("time_spent")
  startedAt           DateTime?        @map("started_at") @db.Timestamptz(6)
  completedAt         DateTime?        @map("completed_at") @db.Timestamptz(6)
  createdAt           DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  aiGeneratedTitle    String?          @map("ai_generated_title") @db.VarChar(255)
  collegeGrade        CollegeGrade?    @map("college_grade")
  examSubject         ExamSubject?     @map("exam_subject")
  higherEdField       String?          @map("higher_ed_field") @db.VarChar(255)
  isSequential        Boolean          @default(false) @map("is_sequential")
  preset              QuizPreset       @default(NONE)
  selectedSpecialties LyceeSpecialty[] @map("selected_specialties")
  sequenceId          String?          @map("sequence_id")
  sequenceOrder       Int?             @map("sequence_order")
  currentSubjectIndex Int?             @default(0) @map("current_subject_index")
  subjectBased        Boolean          @default(false) @map("subject_based")
  subjects            Json?
  hasDocuments        Boolean          @default(false) @map("has_documents")
  sourceDocuments     Json?            @map("source_documents")
  status              String?          @default("ready") @db.VarChar(20)
  targetGrade         Float?           @map("target_grade")
  timeLimit           Int?             @map("time_limit")
  difficulty          String?          @db.VarChar(20)
  questionTypes       Json?            @map("question_types")
  result              QuizResult?
  template            QuizTemplate?    @relation(fields: [templateId], references: [id])
  user                User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("quizzes")
}

model QuizResult {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quizId             String   @unique @map("quiz_id") @db.Uuid
  totalScore         Float    @map("total_score")
  maxScore           Float    @map("max_score")
  percentage         Float
  adaptedGrade       Float    @map("adapted_grade")
  gradeScale         String   @map("grade_scale") @db.VarChar(20)
  detailedScoring    Json     @map("detailed_scoring")
  aiCorrection       Json     @map("ai_correction")
  recommendations    Json     @default("[]")
  strengths          Json     @default("[]")
  weaknesses         Json     @default("[]")
  timeAnalysis       Json?    @map("time_analysis")
  difficultyAnalysis Json?    @map("difficulty_analysis")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  quiz               Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@map("quiz_results")
}

model QuizSequence {
  id                  String           @id @default(cuid())
  userId              String           @map("user_id") @db.VarChar(255)
  preset              QuizPreset
  isCompleted         Boolean          @default(false) @map("is_completed")
  currentSubjectIndex Int              @default(0) @map("current_subject_index")
  totalSubjects       Int              @map("total_subjects")
  subjects            Json
  subjectResults      Json
  globalScore         Float?           @map("global_score")
  globalMaxScore      Float?           @map("global_max_score")
  specialties         LyceeSpecialty[] @default([])
  higherEdField       String?          @map("higher_ed_field") @db.VarChar(255)
  workspaceIds        String[]         @map("workspace_ids") @db.Uuid
  metadata            Json
  createdAt           DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  user                User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("quiz_sequences")
}

model UserSubscription {
  id                   String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId               String             @unique @map("user_id") @db.VarChar(255)
  plan                 SubscriptionPlan   @default(free_user)
  status               SubscriptionStatus @default(active)
  clerkSubscriptionId  String?            @map("clerk_subscription_id") @db.VarChar(255)
  paddleCustomerId     String?            @map("paddle_customer_id") @db.VarChar(255)
  paddleSubscriptionId String?            @map("paddle_subscription_id") @db.VarChar(255)
  currentPeriodStart   DateTime?          @map("current_period_start") @db.Timestamptz(6)
  currentPeriodEnd     DateTime?          @map("current_period_end") @db.Timestamptz(6)
  cancelAtPeriodEnd    Boolean            @default(false) @map("cancel_at_period_end")
  canceledAt           DateTime?          @map("canceled_at") @db.Timestamptz(6)
  trialStart           DateTime?          @map("trial_start") @db.Timestamptz(6)
  trialEnd             DateTime?          @map("trial_end") @db.Timestamptz(6)
  metadata             Json?              @default("{}")
  createdAt            DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([clerkSubscriptionId])
  @@index([paddleSubscriptionId])
  @@index([paddleCustomerId])
  @@map("user_subscriptions")
}

model UsageRecord {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @map("user_id") @db.VarChar(255)
  resourceType String   @map("resource_type") @db.VarChar(50)
  action       String   @db.VarChar(50)
  quantity     Int      @default(1)
  metadata     Json?    @default("{}")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, resourceType])
  @@index([createdAt])
  @@map("usage_records")
}

model UserLimits {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                 String    @unique @map("user_id") @db.VarChar(255)
  aiCreditsUsed          Float     @default(0) @map("ai_credits_used")
  aiCreditsLimit         Float     @default(50) @map("ai_credits_limit")
  workspacesUsed         Int       @default(0) @map("workspaces_used")
  workspacesLimit        Int       @default(2) @map("workspaces_limit")
  projectsUsed           Int       @default(0) @map("projects_used")
  projectsLimit          Int       @default(-1) @map("projects_limit")
  customQuizzesUsed      Int       @default(0) @map("custom_quizzes_used")
  customQuizzesLimit     Int       @default(5) @map("custom_quizzes_limit")
  presetSequencesUsed    Int       @default(0) @map("preset_sequences_used")
  presetSequencesLimit   Int       @default(1) @map("preset_sequences_limit")
  historyQuizzesLimit    Int       @default(5) @map("history_quizzes_limit")
  statsChartsLimit       String[]  @default(["progression-area", "difficulty-radar"]) @map("stats_charts_limit")
  pagesSelectionLimit    Int       @default(2) @map("pages_selection_limit")
  questionsPerQuizLimit  Int       @default(10) @map("questions_per_quiz_limit")
  advancedQuizzesUsed    Int       @default(0) @map("advanced_quizzes_used")
  advancedQuizzesLimit   Int       @default(10) @map("advanced_quizzes_limit")
  advancedQuizzesResetAt DateTime? @map("advanced_quizzes_reset_at") @db.Timestamptz(6)
  lastResetAt            DateTime  @default(now()) @map("last_reset_at") @db.Timestamptz(6)
  resetType              String    @default("monthly") @map("reset_type") @db.VarChar(20)
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  pagesLimit             Int       @default(-1) @map("pages_limit")
  pagesUsed              Int       @default(0) @map("pages_used")
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_limits")
}

enum SchoolLevel {
  COLLEGE
  LYCEE_SECONDE
  LYCEE_PREMIERE
  LYCEE_TERMINALE
  ETUDES_SUPERIEURES
}

enum CollegeGrade {
  SIXIEME
  CINQUIEME
  QUATRIEME
  TROISIEME
}

enum LyceeSpecialty {
  MATHEMATIQUES
  PHYSIQUE_CHIMIE
  SVT
  HISTOIRE_GEO
  SES
  LANGUES_LITTERATURE
  LLCER_ANGLAIS
  LLCER_ESPAGNOL
  LLCER_ALLEMAND
  LLCER_ITALIEN
  ARTS_PLASTIQUES
  MUSIQUE
  THEATRE
  CINEMA_AUDIOVISUEL
  DANSE
  HISTOIRE_DES_ARTS
  NSI
  SI
  SCIENCES_INGENIEUR
  BIOLOGIE_ECOLOGIE
  SPORT
}

enum QuestionType {
  OPEN_QUESTION
  MULTIPLE_CHOICE
  TRUE_FALSE
  MATCHING
}

enum QuizPreset {
  NONE
  BREVET
  BAC
  PARTIELS
}

enum ExamSubject {
  FRANCAIS
  MATHEMATIQUES
  HISTOIRE_GEOGRAPHIE_EMC
  SCIENCES
  PHILOSOPHIE
  GRAND_ORAL
  MATHEMATIQUES_SPE
  PHYSIQUE_CHIMIE_SPE
  SVT_SPE
  SES_SPE
  HGGSP_SPE
  NSI_SPE
  SI_SPE
  LLCER_ANGLAIS_SPE
  LLCER_ESPAGNOL_SPE
  LLCER_ALLEMAND_SPE
  LLCER_ITALIEN_SPE
  ARTS_PLASTIQUES_SPE
  MUSIQUE_SPE
  THEATRE_SPE
  CINEMA_AUDIOVISUEL_SPE
  DANSE_SPE
  HISTOIRE_DES_ARTS_SPE
  BIOLOGIE_ECOLOGIE_SPE
  SPORT_SPE
}

enum BetaStatus {
  active
  inactive
  waitlist
  pending_reactivation
  expired
}

enum SubscriptionPlan {
  free_user
  premium
}

enum SubscriptionStatus {
  active
  canceled
  incomplete
  incomplete_expired
  past_due
  trialing
  unpaid
  ended
}

model Update {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String   @db.VarChar(255)
  date        DateTime @db.Timestamptz(6)
  imageUrl    String   @map("image_url") @db.VarChar(500)
  content     String   @db.Text
  isPublished Boolean  @default(true) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("updates")
}

model DailyArticle {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String   @db.VarChar(500)
  description String   @db.Text
  url         String   @db.VarChar(1000)
  imageUrl    String?  @map("image_url") @db.VarChar(1000)
  publishedAt DateTime @map("published_at") @db.Timestamptz(6)
  fetchedAt   DateTime @default(now()) @map("fetched_at") @db.Timestamptz(6)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([fetchedAt])
  @@map("daily_articles")
}

model OpenaiUsageLog {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quotaKey         String   @default("global") @map("quota_key") @db.VarChar(100)
  userId           String?  @map("user_id") @db.VarChar(100)
  model            String   @db.VarChar(100)
  promptTokens     Int      @map("prompt_tokens")
  completionTokens Int      @map("completion_tokens")
  estimatedCost    Float    @map("estimated_cost")
  source           String?  @map("source") @db.VarChar(50)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([quotaKey, createdAt])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([model, createdAt])
  @@index([source, createdAt])
  @@map("openai_usage_log")
}

// 💬 Conversations avec l'IA
model AIConversation {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String  @map("user_id") @db.VarChar(255)
  workspaceId String? @map("workspace_id") @db.Uuid
  title       String  @db.VarChar(255)

  // État de la conversation
  status         ConversationStatus @default(COMPLETED)
  activeStreamId String?            @map("active_stream_id") @db.VarChar(100)
  isActive       Boolean            @default(true) @map("is_active")
  messageCount   Int                @default(0) @map("message_count")
  lastMessageAt  DateTime?          @map("last_message_at") @db.Timestamptz(6)

  // Métadonnées
  metadata Json @default("{}")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace?  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  messages  AIMessage[]

  @@index([userId])
  @@index([workspaceId])
  @@index([isActive, lastMessageAt])
  @@index([userId, isActive, updatedAt])
  @@map("ai_conversations")
}

// 📝 Messages de conversation
model AIMessage {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String        @map("conversation_id") @db.Uuid
  role           AIMessageRole
  content        String        @db.Text

  // Métadonnées contextuelles
  mentions         Json?   @default("[]") // Pages mentionnées
  files            Json?   @default("[]") // Fichiers joints
  wikipediaSources Json?   @default("[]") @map("wikipedia_sources") // Sources Wikipedia
  mode             String? @db.VarChar(50) // ask, search, create

  // Informations page créée (mode create uniquement)
  pageId        String?  @map("page_id") @db.Uuid // ID de la page créée
  pageTitle     String?  @map("page_title") @db.VarChar(255) // Titre de la page créée
  projectId     String?  @map("project_id") @db.Uuid // ID du projet de la page créée
  isPageDeleted Boolean? @default(false) @map("is_page_deleted") // Statut de suppression de la page

  // 🔥 NOUVEAU: Données complètes de création de page (JSON)
  // Structure: { pageId, pageTitle, pageContent, projectId, status, isComplete, createdAt, deletedAt, recreatedAt }
  pageCreationData Json? @map("page_creation_data") // Données complètes du modal de création

  // 🔥 NOUVEAU: Function Calling (tools utilisés par l'IA)
  thinking     String?  @db.Text // Réflexion de l'IA avant réponse
  toolCalls    Json?    @default("[]") @map("tool_calls") // Liste des tool calls executés
  usedFallback Boolean? @default(false) @map("used_fallback") // Si fallback contexte utilisé (timeout)

  // 🔥 NOUVEAU: Intermediate thinking blocks with generated arguments
  intermediateThinkingBlocks Json? @default("[]") @map("intermediate_thinking_blocks") // [{iteration, thinking, toolArguments, generatedAt}]

  // 💰 NOUVEAU: Métadonnées de coût en crédits (pour analytics et audit)
  creditsMode       String?  @map("credits_mode") @db.VarChar(20) // 'ask', 'search', 'create'
  creditsReflection String?  @map("credits_reflection") @db.VarChar(20) // 'rapide', 'profond'
  creditsHasWeb     Boolean? @default(false) @map("credits_has_web") // Web activé
  creditsHasSources Boolean? @default(false) @map("credits_has_sources") // Sources ajoutées
  creditsUsed       Float?   @map("credits_used") // Coût total calculé (pour référence rapide)

  // Timing
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relations
  conversation AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  page         Page?          @relation(fields: [pageId], references: [id], onDelete: SetNull)

  @@index([conversationId])
  @@index([conversationId, createdAt])
  @@index([pageId])
  @@map("ai_messages")
}

// 🔐 Webhook Event pour idempotence
model WebhookEvent {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId     String   @unique @map("event_id") @db.VarChar(255)
  type        String   @db.VarChar(100)
  processedAt DateTime @default(now()) @map("processed_at") @db.Timestamptz(6)

  @@index([eventId])
  @@index([processedAt])
  @@map("webhook_events")
}

enum AIMessageRole {
  USER
  ASSISTANT
}

enum ConversationStatus {
  IDLE
  STREAMING
  COMPLETED
  ERROR
}

// 🔔 Admin Alerts — automated monitoring alerts
model AdminAlert {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type           AdminAlertType
  severity       AlertSeverity
  message        String         @db.Text
  metadata       Json           @default("{}")
  acknowledged   Boolean        @default(false)
  acknowledgedBy String?        @map("acknowledged_by") @db.VarChar(255)
  acknowledgedAt DateTime?      @map("acknowledged_at") @db.Timestamptz(6)
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([type, createdAt])
  @@index([acknowledged, createdAt])
  @@map("admin_alerts")
}

enum AdminAlertType {
  CHURN_SPIKE
  ERROR_RATE_HIGH
  REVENUE_DROP
  SIGNUPS_SPIKE
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

// 📊 Retention Cohorts — pre-computed weekly retention data
model RetentionCohort {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cohortWeek    String   @map("cohort_week") @db.VarChar(10) // "2026-W09"
  weekNumber    Int      @map("week_number") // 0 = signup week, 1, 2, 3...
  totalUsers    Int      @map("total_users")
  retainedUsers Int      @map("retained_users")
  retentionRate Float    @map("retention_rate") // 0.0 to 100.0
  computedAt    DateTime @default(now()) @map("computed_at") @db.Timestamptz(6)

  @@unique([cohortWeek, weekNumber])
  @@index([cohortWeek])
  @@map("retention_cohorts")
}

// 📝 Admin Notes — internal annotations on users
model AdminNote {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.VarChar(255)
  adminId   String   @map("admin_id") @db.VarChar(255)
  content   String   @db.VarChar(2000)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user  User @relation("AdminNotesOnUser", fields: [userId], references: [id], onDelete: Cascade)
  admin User @relation("AdminNotesByAdmin", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([adminId])
  @@map("admin_notes")
}

// 📊 Quiz Dashboard Layout - Sauvegarde de la disposition personnalisée
model UserDashboardLayout {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String   @unique @map("user_id") @db.VarChar(255)
  layout        Json     @default("[]")
  visibleCharts Json     @default("[]") @map("visible_charts")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_dashboard_layouts")
}
