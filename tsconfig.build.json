{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "incremental": false
  },
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "coverage",
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/__tests__/**",
    "**/test-setup.ts",
    "**/tests/**",
    "prisma/generated",
    "scripts/**",
    "jest.config.js"
  ]
}
