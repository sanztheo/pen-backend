{
  "name": "pen-saas-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "infisical run --path=/Backend/DEV -- tsx watch src/index.ts",
    "dev:local": "NODE_OPTIONS='--max-old-space-size=2048' tsx watch src/index.ts",
    "build": "prisma generate && prisma generate --schema=prisma/schema-embeddings.prisma && tsc -p tsconfig.build.json",
    "start": "NODE_OPTIONS='--max-old-space-size=7168' node dist/index.js",
    "start:infisical": "infisical run --path=/Backend/PROD -- node dist/index.js",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "cleanup:soft-deleted": "tsx src/scripts/cleanupSoftDeletedBlocks.ts",
    "cleanup:dry-run": "DRY_RUN=true tsx src/scripts/cleanupSoftDeletedBlocks.ts",
    "test:cron": "ENABLE_TEST_CRON=true npm run dev",
    "test:load": "tsx test-load.ts",
    "test:load:light": "tsx test-load.ts --users=5 --requests=3",
    "test:load:medium": "tsx test-load.ts --users=20 --requests=10",
    "test:load:heavy": "tsx test-load.ts --users=50 --requests=20",
    "test:load:credits": "tsx test-load.ts --test=credits",
    "test:load:quiz": "tsx test-load.ts --test=quiz",
    "test:scalability": "tsx src/scripts/run-scalability-tests.ts",
    "test:scalability:quick": "tsx src/scripts/run-scalability-tests.ts --quick",
    "test:artillery": "artillery run artillery-websocket.yml",
    "test:artillery:install": "npm install -g artillery",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "test:quiz": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPattern=quiz/intelligence",
    "benchmark:quiz": "tsx scripts/quiz/benchmark-pipeline.ts",
    "benchmark:quiz:small": "tsx scripts/quiz/benchmark-pipeline.ts --scenario=small",
    "benchmark:quiz:medium": "tsx scripts/quiz/benchmark-pipeline.ts --scenario=medium",
    "benchmark:quiz:large": "tsx scripts/quiz/benchmark-pipeline.ts --scenario=large",
    "benchmark:quiz:xlarge": "tsx scripts/quiz/benchmark-pipeline.ts --scenario=xlarge",
    "admin:set": "infisical run --path=/Backend/DEV -- tsx scripts/set-admin.ts",
    "admin:set:prod": "infisical run --path=/Backend/PROD -- tsx scripts/set-admin.ts",
    "test:beta": "npx tsx scripts/test-beta-api.ts",
    "test:beta:curl": "bash scripts/test-beta-api.sh",
    "lint": "eslint src/ --ext .ts --report-unused-disable-directives",
    "lint:errors": "eslint src/ --ext .ts --quiet",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "dependencies": {
    "@ai-sdk/deepseek": "^2.0.0",
    "@ai-sdk/google": "^2.0.49",
    "@ai-sdk/openai": "^2.0.50",
    "@blocknote/server-util": "^0.39.1",
    "@blocknote/xl-ai": "^0.45.0",
    "@clerk/backend": "^2.7.1",
    "@google/generative-ai": "^0.24.1",
    "@paddle/paddle-node-sdk": "^3.5.0",
    "@prisma/client": "^6.12.0",
    "@supabase/supabase-js": "^2.39.0",
    "@xenova/transformers": "^2.17.2",
    "ai": "^5.0.124",
    "bullmq": "^5.63.0",
    "cloudinary": "^2.7.0",
    "compression": "^1.8.0",
    "cors": "^2.8.5",
    "disposable-email-domains-js": "^1.20.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.1.0",
    "helmet": "^7.0.0",
    "ioredis": "^5.8.1",
    "jsonwebtoken": "^9.0.2",
    "lib0": "^0.2.114",
    "mammoth": "^1.6.0",
    "multer": "^1.4.5-lts.1",
    "multiparty": "^4.2.3",
    "nanoid": "^5.1.6",
    "node-cron": "^4.2.1",
    "node-fetch": "^3.3.2",
    "openai": "^5.3.0",
    "papaparse": "^5.4.1",
    "pdf-parse": "^1.1.1",
    "pg": "^8.16.0",
    "railway": "^2.0.17",
    "rate-limit-redis": "^4.2.3",
    "redis": "^4.6.8",
    "rss-parser": "^3.13.0",
    "sharp": "^0.34.4",
    "socket.io": "^4.7.2",
    "svix": "^1.71.0",
    "tiktoken": "^1.0.17",
    "turndown": "^7.1.2",
    "uuid": "^13.0.0",
    "ws": "^8.18.3",
    "y-protocols": "^1.0.6",
    "zod": "^3.21.4"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/multiparty": "^4.2.1",
    "@types/node": "^20.19.1",
    "@types/node-cron": "^3.0.11",
    "@types/node-fetch": "^2.6.13",
    "@types/papaparse": "^5.5.2",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.15.4",
    "@types/supertest": "^2.0.12",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "jest": "^29.6.2",
    "prettier": "^3.8.1",
    "prisma": "^6.14.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "tsx": "^4.7.1",
    "typescript": "^5.9.2"
  }
}
