{
  "name": "pen-saas-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "cleanup:soft-deleted": "tsx src/scripts/cleanupSoftDeletedBlocks.ts",
    "cleanup:dry-run": "DRY_RUN=true tsx src/scripts/cleanupSoftDeletedBlocks.ts",
    "test:cron": "ENABLE_TEST_CRON=true npm run dev",
    "test:load": "tsx test-load.ts",
    "test:load:light": "tsx test-load.ts --users=5 --requests=3",
    "test:load:medium": "tsx test-load.ts --users=20 --requests=10",
    "test:load:heavy": "tsx test-load.ts --users=50 --requests=20",
    "test:load:credits": "tsx test-load.ts --test=credits",
    "test:load:quiz": "tsx test-load.ts --test=quiz",
    "test:scalability": "tsx src/scripts/run-scalability-tests.ts",
    "test:scalability:quick": "tsx src/scripts/run-scalability-tests.ts --quick",
    "test:artillery": "artillery run artillery-websocket.yml",
    "test:artillery:install": "npm install -g artillery"
  },
  "dependencies": {
    "@ai-sdk/openai": "^2.0.50",
    "@blocknote/server-util": "^0.39.1",
    "@blocknote/xl-ai": "^0.41.1",
    "@clerk/backend": "^2.7.1",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^6.12.0",
    "@supabase/supabase-js": "^2.39.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multiparty": "^4.2.1",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.15.4",
    "@xenova/transformers": "^2.17.2",
    "ai": "^5.0.68",
    "cloudinary": "^2.7.0",
    "compression": "^1.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.0.0",
    "ioredis": "^5.8.1",
    "jsonwebtoken": "^9.0.2",
    "lib0": "^0.2.114",
    "mammoth": "^1.6.0",
    "multer": "^1.4.5-lts.1",
    "multiparty": "^4.2.3",
    "node-cron": "^4.1.0",
    "papaparse": "^5.4.1",
    "node-fetch": "^3.3.2",
    "openai": "^5.3.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.16.0",
    "railway": "^2.0.17",
    "redis": "^4.6.8",
    "rss-parser": "^3.13.0",
    "sharp": "^0.34.4",
    "socket.io": "^4.7.2",
    "svix": "^1.71.0",
    "turndown": "^7.1.2",
    "uuid": "^13.0.0",
    "ws": "^8.18.3",
    "y-protocols": "^1.0.6",
    "zod": "^3.21.4"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.3",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.19.1",
    "@types/node-fetch": "^2.6.13",
    "@types/pdf-parse": "^1.1.5",
    "@types/supertest": "^2.0.12",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "jest": "^29.6.2",
    "prisma": "^6.14.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "tsx": "^4.7.1",
    "typescript": "^5.9.2"
  }
}
