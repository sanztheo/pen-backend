# ─────────────────────────────────────────────────────────────────
# Pennote Backend — Configuration
# Copy this file to .env and fill in the values.
# In production we use Infisical: `infisical run --env=prod --path=/Backend`.
# Never commit .env or any file containing real secrets.
# ─────────────────────────────────────────────────────────────────

# ─── Runtime ──────────────────────────────────────────────────────

# Optional. Defaults to 3001.
PORT=3001

# Optional. "development" | "production" | "test"
NODE_ENV=development

# Required. Must equal 1 — single-replica boot guard.
# Multi-replica deployment requires distributed mutex (not implemented).
REPLICA_COUNT=1

# ─── Database (Postgres) ──────────────────────────────────────────

# Required. Main app database connection string.
# Tables: users, workspaces, projects, pages, conversations, etc.
DATABASE_URL=postgresql://user:password@localhost:5432/pennote

# Required. Separate Postgres database with pgvector extension installed.
# Used for RAG embeddings (page chunks, message memory).
# CREATE EXTENSION IF NOT EXISTS vector;
EMBEDDING_DATABASE_URL=postgresql://user:password@localhost:5432/pennote_embeddings

# ─── Cache & queues (Redis) ───────────────────────────────────────

# Required. Redis connection (rate limiting, session cache, BullMQ jobs).
REDIS_URL=redis://localhost:6379

# Optional. Public Redis URL (Railway-specific — used as fallback).
REDIS_PUBLIC_URL=

# ─── Frontend ─────────────────────────────────────────────────────

# Required. Frontend SPA URL — used for CORS allowlist and email links.
CLIENT_URL=http://localhost:5173

# ─── Auth (Clerk) ─────────────────────────────────────────────────

# Required. https://dashboard.clerk.com/last-active?path=api-keys
CLERK_SECRET_KEY=sk_test_...

# ─── Encryption ───────────────────────────────────────────────────

# Required. 32-character hex string. Generate with: openssl rand -hex 32
# Used to encrypt sensitive fields at rest (e.g. agent toolset configs).
ENCRYPTION_KEY=

# ─── AI providers (at least one required) ────────────────────────

# Recommended. https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Optional. https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional. https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Optional. https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# Optional. https://platform.moonshot.cn/
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=

# Optional. https://docs.x.ai/
XAI_API_KEY=

# Optional. https://console.mistral.ai/
MISTRAL_API_KEY=

# ─── AI tuning ────────────────────────────────────────────────────

# Optional. Default model for chat. e.g. "gpt-5", "claude-haiku-4-5"
OPENAI_MODEL=

# Optional. Hourly request quota (defaults conservative).
OPENAI_MAX_REQUESTS_PER_HOUR=
MAX_TOKENS_PER_HOUR=
MAX_COST_PER_HOUR=

# Optional. Timeout for AI calls in ms.
AI_TIMEOUT_MS=60000

# Optional. RAG embedding parallelism.
RAG_EMBEDDING_CONCURRENCY=4
RAG_DB_BATCH_SIZE=50

# ─── Billing (Paddle) ─────────────────────────────────────────────

# Required if billing is enabled.
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_ENVIRONMENT=sandbox  # "sandbox" | "production"

# Required if billing enabled. Paddle product/price IDs.
PRODUCT=
PREMIUMMONTHLY=
PREMIUMYEARLY=
ULTRAPRODUCT=
ULTRAMONTHLY=
ULTRAYEARLY=

# ─── Email (Resend) ───────────────────────────────────────────────

# Required if email features enabled.
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com
FEEDBACK_EMAIL=feedback@yourdomain.com

# ─── Uploads (Cloudinary) ─────────────────────────────────────────

# Required if uploads enabled. Format: cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_URL=

# ─── Captcha (Cloudflare Turnstile) ───────────────────────────────

# Optional. https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SECRET_KEY=

# ─── Notifications ────────────────────────────────────────────────

# Optional. Slack incoming webhook for admin alerts.
SLACK_WEBHOOK_URL=

# ─── Rate limiting ────────────────────────────────────────────────

RATE_LIMIT_ENABLED=true
RATE_LIMIT_WS_CONNECTIONS=10
RATE_LIMIT_WS_MESSAGES=60

# ─── Test / debug ─────────────────────────────────────────────────

# DANGEROUS. If true, /test-auth endpoint creates JWTs without Clerk.
# Never enable in production.
ENABLE_TEST_AUTH=false
TEST_AUTH_SECRET=

# Required if account deletion endpoint is enabled.
ENABLE_ACCOUNT_DELETION=false

# Optional. Cron job test endpoints.
ENABLE_TEST_CRON=false

# Optional. Verbose debug logs.
DEBUG=
